NODE_ENV=production
PORT=5000

# MongoDB Atlas production database.
MONGO_URI=mongodb+srv://gaurav_nursery_api:<password>@<cluster-host>/gaurav_nursery_prod?retryWrites=true&w=majority

# Generate a fresh long random value for production.
JWT_SECRET=<at-least-32-random-bytes>
JWT_EXPIRES_IN=7d

# Frontend production origins.
CLIENT_URL=https://gauravnursery.online
CORS_ORIGINS=https://gauravnursery.online,https://www.gauravnursery.online

# API rate limiting.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Cloudinary product image uploads.
CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>

# Razorpay live payments.
RAZORPAY_KEY_ID=<razorpay-live-key-id>
RAZORPAY_KEY_SECRET=<razorpay-live-key-secret>
